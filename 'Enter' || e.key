<file path="src/entities/__tests__/Todo.server.test.ts">
import 'reflect-metadata';
import { DataSource, Repository } from 'typeorm';
import { Todo } from '../Todo';

describe('Todo Entity', () => {
  let dataSource: DataSource;
  let repo: Repository<Todo>;

  beforeAll(async () => {
    dataSource = new DataSource({
      type: 'better-sqlite3',
      database: ':memory:',
      entities: [Todo],
      synchronize: true,
      logging: false,
    });
    await dataSource.initialize();
    repo = dataSource.getRepository(Todo);
  });

  afterAll(async () => {
    if (dataSource && dataSource.isInitialized) {
      await dataSource.destroy();
    }
  });

  afterEach(async () => {
    await repo.clear();
  });

  it('should create a todo with required fields', async () => {
    const todo = repo.create({
      title: 'Test Todo',
      completed: false,
      description: null,
    });
    const saved = await repo.save(todo);

    expect(saved.id).toBeDefined();
    expect(saved.title).toBe('Test Todo');
    expect(saved.completed).toBe(false);
    expect(saved.description).toBeNull();
    expect(saved.createdAt).toBeDefined();
    expect(saved.updatedAt).toBeDefined();
  });

  it('should create a todo with description', async () => {
    const todo = repo.create({
      title: 'Test Todo',
      description: 'A description',
      completed: false,
    });
    const saved = await repo.save(todo);

    expect(saved.description).toBe('A description');
  });

  it('should update a todo', async () => {
    const todo = repo.create({
      title: 'Original',
      completed: false,
      description: null,
    });
    const saved = await repo.save(todo);

    saved.title = 'Updated';
    saved.completed = true;
    const updated = await repo.save(saved);

    expect(updated.title).toBe('Updated');
    expect(updated.completed).toBe(true);
    expect(updated.id).toBe(saved.id);
  });

  it('should delete a todo', async () => {
    const todo = repo.create({
      title: 'To Delete',
      completed: false,
      description: null,
    });
    const saved = await repo.save(todo);
    const id = saved.id;

    await repo.remove(saved);

    const found = await repo.findOne({ where: { id } });
    expect(found).toBeNull();
  });

  it('should find todos ordered by createdAt DESC', async () => {
    const todo1 = repo.create({ title: 'First', completed: false, description: null });
    await repo.save(todo1);

    // Small delay to ensure different timestamps
    await new Promise((r) => setTimeout(r, 10));

    const todo2 = repo.create({ title: 'Second', completed: false, description: null });
    await repo.save(todo2);

    const todos = await repo.find({ order: { createdAt: 'DESC' } });
    expect(todos).toHaveLength(2);
    expect(todos[0].title).toBe('Second');
    expect(todos[1].title).toBe('First');
  });

  it('should default completed to false', async () => {
    const todo = repo.create({
      title: 'Default completed',
      description: null,
    });
    // completed defaults to false via column default
    const saved = await repo.save(todo);
    // SQLite + TypeORM: the default is applied
    expect(saved.completed